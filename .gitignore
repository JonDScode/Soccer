# Datos: no versionar datasets crudos, solo el código que los genera/descarga.
# Excepción: los Parquet procesados (~300 KB) van al repo para que el deploy
# en Streamlit Cloud arranque sin pipeline; los eventos crudos se descargan
# al vuelo desde StatsBomb cuando no están en disco.
data/raw/*
data/processed/*
data/synthetic/*
!data/processed/*.parquet
!data/**/.gitkeep

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/

# DuckDB / SQLite locales
*.duckdb
*.db

# Entornos / secretos (API keys de football-data.org, etc.)
.env

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Assets personales de publicaciones
reports/linkedin/

# Mundial 2026 (datos de WhoScored via nlbair/wc2026-events, sin licencia): solo uso local
notebooks/03_mundial2026_grafos.ipynb
reports/figures/*_LOCAL*
